---
title: WASAC/REG Utility Billing System — Spring Boot Flow
---

flowchart TB
    subgraph Client["Client"]
        APP["Web / Mobile / Swagger UI"]
    end

    subgraph Security["Security"]
        JWT["JWT Authentication\n(Signup, Login, Role-based access)"]
    end

    subgraph API["REST API Layer"]
        CTRL["Controllers\nAuth | Users | Customers | Meters\nReadings | Tariffs | Bills\nPayments | Notifications"]
    end

    subgraph Service["Service Layer"]
        SVC["Business Logic & Rules\n• User signup → ROLE_CUSTOMER\n• Meter reading validation\n• Tariff & bill calculation\n• Partial / full payments\n• Notifications & emails"]
    end

    subgraph Data["Data Layer"]
        JPA["Spring Data JPA Repositories"]
    end

    subgraph DB["PostgreSQL"]
        PG[("Tables + Flyway Migrations")]
        TRIG["DB Trigger: auto-set bill PAID\nwhen balance = 0"]
        FUNC["DB Function: apply_overdue_penalties()"]
    end

    SMTP["SMTP Email Server"]

    APP --> JWT --> CTRL --> SVC --> JPA --> PG
    SVC --> SMTP
    SVC --> FUNC
    PG --> TRIG
    FUNC --> PG

    %% Main business flows
    subgraph Flow1["1. Authentication"]
        A1["Register"] --> A2["Login"] --> A3["JWT Token"]
    end

    subgraph Flow2["2. Billing"]
        B1["Operator: capture reading"] --> B2["Finance: generate bill"]
        B2 --> B3["Notify customer\n(in-app + email)"]
        B3 --> B4["Finance: approve bill"]
    end

    subgraph Flow3["3. Payment"]
        P1["Record payment"] --> P2{"Full pay?"}
        P2 -->|Yes| P3["Status → PAID + notify"]
        P2 -->|No| P4["Update balance + notify"]
    end

    subgraph Flow4["4. Late Penalty"]
        L1["Admin: configure penalty"] --> L2["Finance/Admin: trigger job"]
        L2 --> L3["Apply fee on overdue bills"]
    end

    JWT -.-> Flow1
    SVC -.-> Flow2
    SVC -.-> Flow3
    SVC -.-> Flow4

    subgraph Roles["Roles"]
        R1["ADMIN — config & users"]
        R2["OPERATOR — readings"]
        R3["FINANCE — bills & payments"]
        R4["CUSTOMER — view own data"]
    end
